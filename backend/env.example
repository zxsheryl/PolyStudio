# 后端环境变量示例（请复制为 .env 并填写真实值）
#
# 复制命令：
#   cd PolyStudio/backend
#   cp env.example .env

# OpenAI 兼容接口（默认 SiliconFlow）
OPENAI_API_KEY=YOUR_API_KEY_HERE
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
MODEL_NAME=deepseek-ai/DeepSeek-V3.1-Terminus

# 图像生成/编辑模型（SiliconFlow images 接口使用）
IMAGE_MODEL_NAME=Qwen/Qwen-Image
EDIT_IMAGE_MODEL_NAME=Qwen/Qwen-Image-Edit-2509

# 用于将本地 /storage/... 拼成可访问的完整 URL（edit_image 需要）
BASE_URL=http://localhost:8000

# LangGraph 多步推理递归上限
RECURSION_LIMIT=200

# 火山引擎图片生成 API 配置
VOLCANO_API_KEY=YOUR_VOLCANO_API_KEY_HERE
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_IMAGE_MODEL=seedream-4.5
VOLCANO_EDIT_MODEL=seedream-4.5

# 腾讯云混元生3D API 配置 https://console.cloud.tencent.com/ai3d/packages
TENCENT_AI3D_API_KEY=YOUR_TENCENT_AI3D_API_KEY_HERE
TENCENT_AI3D_BASE_URL=https://api.ai3d.cloud.tencent.com

# 日志配置
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Mock 模式（用于调试 agent，不调用真实 API）
# 设置为 true 时，图片生成和3D生成将返回固定的 mock 数据
# ⚠️ 注意：启用 MOCK_MODE=true 时，必须配置 MOCK_IMAGE_PATH 和 MOCK_MODEL_PATH
MOCK_MODE=false
# Mock 图片路径（启用 MOCK_MODE 时必须配置，必须是 /storage/images/ 下的文件路径）
# 例如：/storage/images/your_mock_image.png
MOCK_IMAGE_PATH=
# Mock 3D模型路径（启用 MOCK_MODE 时必须配置，必须是 /storage/models/ 下的模型目录路径）
# 例如：/storage/models/your_model_dir
MOCK_MODEL_PATH=